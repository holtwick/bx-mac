# Apple code signing and notarization (used by `pnpm sign`)
# Copy to .env and fill in your values.

# Signing identity (find yours with: security find-identity -v -p codesigning)
APPLE_IDENTITY="Developer ID Application: Joe (XXXXXXXXXX)"

# Notarization credentials
APPLE_ID=your@apple.id
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_APP_PWD=xxxx-xxxx-xxxx-xxxx
